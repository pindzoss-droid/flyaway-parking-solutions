# ===== Klijent (Vite, ubacuje se u build) =====
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ===== Server (Node runtime, koristi ih TanStack server functions) =====
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
# Service role — TAJNO. Nikad ne stavljati u VITE_ varijable. Koristi se za admin operacije.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ===== Node server =====
# ===== Node server =====
NODE_ENV="production"
PORT=3000
HOST="127.0.0.1"

# ===== Email (Resend) =====
# API ključ generisan na https://resend.com (Tajno — samo na serveru)
RESEND_API_KEY=""
# Sender adresa (mora biti na verifikovanoj domeni notify.parkandfly.ba)
EMAIL_FROM="noreply@notify.parkandfly.ba"
# Interni primalac kojem stiže notifikacija o novoj rezervaciji
ADMIN_EMAIL="parkandflyba@gmail.com"
